# CuckooBot Environment Variables
# Copy to .env for local testing: cp .env.example .env

# Required: Path to underworld3 repository clone
BOT_REPO_PATH=/Users/lmoresi/+Underworld/underworld-pixi-2/underworld3

# Huggingface token for faster loading of sentence-transformers (or any model from HF)
# Just go to huggingface.co/settings/tokens and generate a read-only token
# Not a super-needed step though
# HF_TOKEN=hf

# Required: Anthropic API key for Claude
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Optional: Claude model to use (default: claude-3-5-sonnet-20241022)
# Available: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Optional: Base URL for GitHub file links
BOT_BASE_URL=https://github.com/underworldcode/underworld3/blob/main

# Optional: Maximum file size to index (bytes)
BOT_MAX_FILE_SIZE=200000

# Optional: Allowed file extensions (comma-separated)
BOT_ALLOWED_EXTS=.py,.md,.txt,.c,.h,.hpp,.cpp,.json,.yaml,.yml,.toml,.sh,.typ

# Optional: Directory to persist the ChromaDB vector index (default: ./index_cache)
# BOT_INDEX_CACHE=./index_cache

# Optional: Set to 1 to force a full reindex on next startup (clears existing index)
# BOT_FORCE_REBUILD=0

# Optional: Embedding model for indexing and retrieval (default: BAAI/bge-base-en-v1.5)
# Changing this requires BOT_FORCE_REBUILD=1 to rebuild the index with the new model
# BOT_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# BOT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5  # smaller/faster alternative

# Optional: Enable hybrid BM25 + vector RRF retrieval (default: off)
# Eval result: hurts Class A (rag-specific) context_recall (-0.131) and answer_relevancy (-0.142)
# for domain-specific questions. May improve after domain fine-tuning of the embedding model.
# BOT_HYBRID_SEARCH=1

# HyDE retrieval — embeds a generated hypothetical answer instead of the raw question (default: on)
# Eval result: Class A context_recall +0.071, faithfulness +0.036, answer_relevancy +0.025.
# Costs one extra Claude call per query (~200ms). Set to 0 to disable.
# BOT_HYDE=0
